# =============================================================
#  TaskFlow Pro — Variables de Entorno
#  Copia este archivo como .env.local para desarrollo local
# =============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="TaskFlow Pro"

# ── Base de Datos (PostgreSQL) ────────────────────────────────
DATABASE_URL="postgresql://taskflow:taskflow_password@localhost:5432/taskflow_db"
DATABASE_URL_UNPOOLED="postgresql://taskflow:taskflow_password@localhost:5432/taskflow_db"

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ── Autenticación JWT ─────────────────────────────────────────
# Genera con: openssl rand -base64 64
JWT_SECRET="CAMBIA_ESTO_POR_UN_SECRETO_MUY_LARGO_Y_ALEATORIO"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CAMBIA_ESTO_TAMBIEN_POR_OTRO_SECRETO_DIFERENTE"
JWT_REFRESH_EXPIRES_IN="7d"

# ── OAuth GitHub ──────────────────────────────────────────────
# Crear en: https://github.com/settings/apps
GITHUB_CLIENT_ID="tu_github_client_id"
GITHUB_CLIENT_SECRET="tu_github_client_secret"
GITHUB_CALLBACK_URL="http://localhost:3000/api/auth/oauth/github/callback"

# ── APIs Externas (todas gratuitas, sin tarjeta) ──────────────
# Open-Meteo: No requiere key — https://open-meteo.com
NEXT_PUBLIC_OPEN_METEO_URL="https://api.open-meteo.com/v1"

# NewsAPI: Registra gratis en https://newsapi.org
NEWS_API_KEY="tu_newsapi_key"
NEWS_API_URL="https://newsapi.org/v2"

# ExchangeRate: Registra gratis en https://exchangerate-api.com
EXCHANGE_RATE_API_KEY="tu_exchangerate_api_key"
EXCHANGE_RATE_URL="https://v6.exchangerate-api.com/v6"

# IPInfo: Gratis hasta 50k req/mes — https://ipinfo.io
IPINFO_TOKEN="tu_ipinfo_token"

# Dicebear: No requiere key — https://dicebear.com
NEXT_PUBLIC_DICEBEAR_URL="https://api.dicebear.com/9.x"

# ── Sentry (monitoreo de errores — free tier) ─────────────────
# Registra en: https://sentry.io
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ── WebSockets ────────────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# ── Métricas ──────────────────────────────────────────────────
PROMETHEUS_PORT=9090
METRICS_SECRET="secreto_para_endpoint_metrics"

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL="debug"

# ── Docker (solo para docker-compose) ────────────────────────
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_password
POSTGRES_DB=taskflow_db
GRAFANA_ADMIN_PASSWORD=admin123
